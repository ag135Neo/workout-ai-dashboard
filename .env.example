# Required only for real photo extraction. Without it, /upload returns a demo extraction.
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4.1-mini

# Optional: Supabase DB persistence. Without this, sessions save to browser localStorage only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: a readable starting user id for local testing. The app also creates a browser-specific id.
NEXT_PUBLIC_DEMO_USER_ID=demo-user
